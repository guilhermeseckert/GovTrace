# GovTrace — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string
# Local dev: use docker-compose.override.yml to expose postgres on 127.0.0.1:5432
DATABASE_URL=postgres://govtrace:govtrace@localhost:5432/govtrace

# Anthropic API key — required for entity matching (Claude Batch API) and AI summaries
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Web server port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development
